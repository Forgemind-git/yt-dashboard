# YouTube OAuth2 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yt.srv879786.hstgr.cloud/api/auth/callback
YOUTUBE_REFRESH_TOKEN=

# YouTube Channel
YOUTUBE_CHANNEL_ID=

# Database (connects to existing nocobase-db container)
DATABASE_URL=postgresql://nocobase:nocobasepass123@nocobase-db:5432/yt_analytics
PG_SUPERUSER_URL=postgresql://nocobase:nocobasepass123@nocobase-db:5432/postgres

# Backend
PORT=3001
NODE_ENV=production

# Frontend (build-time)
VITE_API_URL=https://yt.srv879786.hstgr.cloud/api
